+impl fmt::Debug for UdpSocket {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.debug_struct(stringify!(UdpSocket))
+            .field("ri", &self.inner.ri())
+            .field("addr", &self.socket_addr().expect("Shouldn't fail"))
+            .finish()
+    }
+}

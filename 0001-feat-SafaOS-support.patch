@@ -0,0 +1,24 @@
+//! Unwinding for safaos target.
+//!
+//! Right now we don't support this, so this is just stubs.
+
+use alloc::boxed::Box;
+use core::any::Any;
+
+pub(crate) unsafe fn cleanup(_ptr: *mut u8) -> Box<dyn Any + Send> {
+    unsafe extern "C" {
+        fn __rust_abort() -> !;
+    }
+    unsafe {
+        __rust_abort();
+    }
+}
+
+pub(crate) unsafe fn panic(_data: Box<dyn Any + Send>) -> u32 {
+    unsafe extern "C" {
+        fn __rust_abort() -> !;
+    }
+    unsafe {
+        __rust_abort();
+    }
+}

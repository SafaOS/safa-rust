+use safa_api::errors::ErrorStatus;
+
+use crate::io;
+use crate::sys::io::RawOsError;
+
+pub fn errno() -> RawOsError {
+    (ErrorStatus::Unknown as u16).into()
+}
+
+pub fn is_interrupted(_code: io::RawOsError) -> bool {
+    false // SafaOS doesn't have signals.
+}
+
+pub fn decode_error_kind(code: io::RawOsError) -> io::ErrorKind {
+    if code < 0 || code > u16::MAX.into() {
+        return io::ErrorKind::Uncategorized;
+    }
+
+    let Ok(err) = ErrorStatus::try_from_u16(code as u16) else {
+        return io::ErrorKind::Uncategorized;
+    };
+
+    let results = crate::os::safaos::into_io_error_kind(err);
+    results
+}
+
+pub fn error_string(errno: RawOsError) -> String {
+    let error: ErrorStatus = match errno {
+        x if x < 0 => ErrorStatus::Unknown,
+        x if x > u16::MAX.into() => ErrorStatus::Unknown,
+        x => ErrorStatus::try_from_u16(x as u16).unwrap_or(ErrorStatus::Unknown), /* u16 */
+    };
+    format!("{}", error.as_str())
+}
